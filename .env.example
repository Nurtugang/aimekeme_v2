# Устройство инференса (общее для всех моделей): auto | cuda | cpu | cuda:0 ...
DEVICE=auto

# fight: порог решения P(fight) >= threshold => label "fight".
FIGHT_THRESHOLD=0.5

# face: косинусная близость (ArcFace) >= threshold => лицо узнано (иначе "unknown").
FACE_MATCH_THRESHOLD=0.42

# face: порог уверенности детектора лиц (insightface).
FACE_DET_THRESH=0.5

KNOWN_FACES_DIR=known_faces

# Скопируй в .env и поправь при необходимости.

# Устройство инференса (общее для всех моделей): auto | cuda | cpu | cuda:0 ...
DEVICE=auto

# fight: порог решения P(fight) >= threshold => label "fight".
FIGHT_THRESHOLD=0.5

# face: косинусная близость >= threshold => лицо узнано (иначе "unknown").
FACE_MATCH_THRESHOLD=0.6
# папка с фото известных людей (<имя>.jpg).
KNOWN_FACES_DIR=known_faces
